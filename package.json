{
  "name": "saascode-kit",
  "version": "2.0.0-alpha.1",
  "description": "SaaS development guardrails. Free. Offline. Deterministic.",
  "type": "module",
  "bin": {
    "saascode": "./dist/cli/index.js",
    "saascode-check": "./dist/cli/check-standalone.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:legacy": "bash tests/run-tests.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "ts-morph": "^24.0.0",
    "yaml": "^2.5.0",
    "glob": "^11.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist/",
    "scripts/ast-review.ts",
    "scripts/ast-review-python.py",
    "scripts/ast-review-go.sh",
    "scripts/ast-review-java.sh",
    "scripts/ast-review-ruby.sh",
    "scripts/ast-review.sh",
    "scripts/endpoint-parity.sh",
    "scripts/check-file.sh",
    "scripts/review-formatter.sh",
    "scripts/review-checks.sh",
    "scripts/recommend.sh",
    "scripts/lib.sh",
    "templates/semgrep/",
    "templates/eslint/",
    "templates/prettier/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "saas",
    "code-review",
    "endpoint-parity",
    "security",
    "guardrails",
    "devtools",
    "multi-tenant",
    "ast-review"
  ],
